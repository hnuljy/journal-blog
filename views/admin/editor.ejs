<%- include("../partials/header", { pageTitle }) %>

<section class="panel">
  <div class="section-heading">
    <h1><%= pageTitle %></h1>
    <% if (post.id && post.status === "published") { %>
      <a class="text-link" href="/posts/<%= post.slug %>" target="_blank" rel="noreferrer">Open public page</a>
    <% } %>
  </div>

  <form action="<%= submitAction %>" method="post" class="stack-form">
    <label>
      <span>Title</span>
      <input name="title" value="<%= post.title %>" maxlength="120" required />
    </label>
    <label>
      <span>Slug</span>
      <input name="slug" value="<%= post.slug %>" maxlength="150" placeholder="optional-auto-generated" />
    </label>
    <label>
      <span>Cover image URL</span>
      <input name="coverImage" value="<%= post.cover_image %>" maxlength="500" placeholder="https://example.com/image.jpg" />
    </label>
    <label>
      <span>Excerpt</span>
      <textarea name="excerpt" rows="3" maxlength="240" placeholder="optional-summary"><%= post.excerpt %></textarea>
    </label>
    <label>
      <span>Content</span>
      <textarea name="content" rows="14" required><%= post.content %></textarea>
    </label>
    <label>
      <span>Status</span>
      <select name="status">
        <option value="draft" <%= post.status === "draft" ? "selected" : "" %>>Draft</option>
        <option value="published" <%= post.status === "published" ? "selected" : "" %>>Published</option>
      </select>
    </label>
    <button class="button" type="submit"><%= submitLabel %></button>
  </form>
</section>

<%- include("../partials/footer") %>
