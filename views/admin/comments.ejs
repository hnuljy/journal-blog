<%- include("../partials/header", { pageTitle }) %>

<section class="panel">
  <div class="section-heading">
    <h1>Comments</h1>
    <span><%= comments.length %> total</span>
  </div>

  <% if (!comments.length) { %>
    <div class="empty-state">
      <h3>No comments received</h3>
      <p>Comments from readers will appear here after they are submitted.</p>
    </div>
  <% } %>

  <div class="comment-list">
    <% comments.forEach((comment) => { %>
      <article class="comment-item admin-comment">
        <div class="comment-top">
          <div>
            <strong><%= comment.author_name %></strong>
            <div class="table-note"><%= comment.author_email || "No email provided" %></div>
          </div>
          <span><%= formatDate(comment.created_at) %></span>
        </div>
        <p><%= comment.content %></p>
        <div class="actions">
          <a class="text-link" href="/posts/<%= comment.post_slug %>" target="_blank" rel="noreferrer">View post</a>
          <span class="table-note"><%= comment.post_title %></span>
          <form action="/admin/comments/<%= comment.id %>?_method=DELETE" method="post" class="inline-form">
            <button class="link-button danger" type="submit">Delete</button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include("../partials/footer") %>
