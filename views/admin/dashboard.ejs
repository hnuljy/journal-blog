<%- include("../partials/header", { pageTitle }) %>

<section class="stats-grid">
  <article class="stat-card">
    <span>Total posts</span>
    <strong><%= stats.postCount %></strong>
  </article>
  <article class="stat-card">
    <span>Published posts</span>
    <strong><%= stats.publishedCount %></strong>
  </article>
  <article class="stat-card">
    <span>Total comments</span>
    <strong><%= stats.commentCount %></strong>
  </article>
</section>

<section class="panel">
  <div class="section-heading">
    <h1>Posts</h1>
    <a class="button" href="/admin/posts/new">New post</a>
  </div>

  <% if (!posts.length) { %>
    <div class="empty-state">
      <h3>No posts created</h3>
      <p>Use the editor to create a draft or publish your first article.</p>
    </div>
  <% } %>

  <% if (posts.length) { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Comments</th>
            <th>Updated</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% posts.forEach((post) => { %>
            <tr>
              <td>
                <strong><%= post.title %></strong>
                <div class="table-note">/<%= post.slug %></div>
              </td>
              <td><span class="badge badge-<%= post.status %>"><%= post.status %></span></td>
              <td><%= post.comment_count %></td>
              <td><%= formatDate(post.updated_at) %></td>
              <td class="actions">
                <a class="text-link" href="/admin/posts/<%= post.id %>/edit">Edit</a>
                <% if (post.status === "published") { %>
                  <a class="text-link" href="/posts/<%= post.slug %>" target="_blank" rel="noreferrer">View</a>
                <% } %>
                <form action="/admin/posts/<%= post.id %>?_method=DELETE" method="post" class="inline-form">
                  <button class="link-button danger" type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("../partials/footer") %>
