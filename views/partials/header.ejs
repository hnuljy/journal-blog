<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | <%= siteTitle %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href="/">Journal Blog</a>
        <nav class="nav">
          <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
          <% if (isAdmin) { %>
            <a class="<%= currentPath === '/admin' ? 'active' : '' %>" href="/admin">Dashboard</a>
            <a class="<%= currentPath === '/admin/comments' ? 'active' : '' %>" href="/admin/comments">Comments</a>
            <a href="/admin/posts/new">New Post</a>
            <form action="/admin/logout" method="post" class="inline-form">
              <button class="link-button" type="submit">Sign out</button>
            </form>
          <% } else { %>
            <a class="<%= currentPath === '/admin/login' ? 'active' : '' %>" href="/admin/login">Admin</a>
          <% } %>
        </nav>
      </header>

      <% if (flash) { %>
        <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
      <% } %>

      <main class="page">
